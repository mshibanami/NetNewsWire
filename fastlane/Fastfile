default_platform(:ios)

TEAM_ID = "ZVWN4UJS9M"
ORGANIZATION_IDENTIFIER = "io.github.mshibanami"

APP_IDENTIFIERS = {
  ios: [
    "io.github.mshibanami.NetNewsWire.iOS",
    "io.github.mshibanami.NetNewsWire.iOS.IntentsExtension",
    "io.github.mshibanami.NetNewsWire.iOS.SpringboardWidgets",
    "io.github.mshibanami.NetNewsWire.iOS.Share-Extension"
  ],
  macos: [
    "io.github.mshibanami.NetNewsWire-Evergreen",
    "io.github.mshibanami.NetNewsWire-Evergreen.Mac.ShareExtension",
    "io.github.mshibanami.NetNewsWire-Evergreen.SubscribeToFeed"
  ]
}

TARGET_MAP = {
  ios: {
    "NetNewsWire-iOS" => "io.github.mshibanami.NetNewsWire.iOS",
    "NetNewsWire iOS Intents Extension" => "io.github.mshibanami.NetNewsWire.iOS.IntentsExtension",
    "NetNewsWire iOS Widget Extension" => "io.github.mshibanami.NetNewsWire.iOS.SpringboardWidgets",
    "NetNewsWire iOS Share Extension" => "io.github.mshibanami.NetNewsWire.iOS.Share-Extension"
  },
  macos: {
    "NetNewsWire" => "io.github.mshibanami.NetNewsWire-Evergreen",
    "Subscribe to Feed" => "io.github.mshibanami.NetNewsWire-Evergreen.SubscribeToFeed",
    "NetNewsWire Share Extension" => "io.github.mshibanami.NetNewsWire-Evergreen.Mac.ShareExtension"
  }
}

def api_key
  return nil unless ENV["APP_STORE_CONNECT_API_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"] && ENV["APP_STORE_CONNECT_API_KEY"]

  @api_key ||= app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY"],
    is_key_content_base64: false
  )
end

def sync_signing(platform:, readonly:)
  match_options = {
    type: "appstore",
    platform: platform.to_s,
    readonly: readonly,
    app_identifier: APP_IDENTIFIERS[platform],
    api_key: api_key
  }.compact

  match(**match_options)
  lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
end

def configure_signing(platform:, profiles:)
  TARGET_MAP[platform].each do |target_name, bundle_identifier|
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "NetNewsWire.xcodeproj",
      team_id: TEAM_ID,
      targets: [target_name],
      bundle_identifier: bundle_identifier,
      profile_name: profiles.fetch(bundle_identifier)
    )
  end
end

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do |options|
    profiles = sync_signing(platform: :ios, readonly: is_ci)
    configure_signing(platform: :ios, profiles: profiles)

    gym(
      scheme: "NetNewsWire-iOS",
      project: "NetNewsWire.xcodeproj",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: TEAM_ID,
        signingStyle: "manual",
        provisioningProfiles: profiles,
        manageAppVersionAndBuildNumber: true
      },
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} ORGANIZATION_IDENTIFIER=#{ORGANIZATION_IDENTIFIER} CURRENT_PROJECT_VERSION=#{options[:build_number]}"
    )

    pilot(
      api_key: api_key,
      distribute_external: true,
      skip_waiting_for_build_processing: false,
      changelog: "Automated build from GitHub Actions"
    )
  end

  desc "Sync iOS signing assets"
  lane :sync_signing do
    sync_signing(platform: :ios, readonly: false)
  end
end

platform :mac do
  desc "Push a new build to App Store Connect for Mac"
  lane :release do |options|
    profiles = sync_signing(platform: :macos, readonly: is_ci)
    configure_signing(platform: :macos, profiles: profiles)

    gym(
      scheme: "NetNewsWire",
      project: "NetNewsWire.xcodeproj",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        teamID: TEAM_ID,
        signingStyle: "manual",
        provisioningProfiles: profiles
      },
      xcargs: "DEVELOPMENT_TEAM=#{TEAM_ID} ORGANIZATION_IDENTIFIER=#{ORGANIZATION_IDENTIFIER} CURRENT_PROJECT_VERSION=#{options[:build_number]}"
    )

    pilot(
      api_key: api_key,
      distribute_external: true,
      skip_waiting_for_build_processing: false,
      changelog: "Automated build from GitHub Actions"
    )
  end

  desc "Sync macOS signing assets"
  lane :sync_signing do
    sync_signing(platform: :macos, readonly: false)
  end
end
